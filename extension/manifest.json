{
  "manifest_version": 3,
  "name": "Memory OS",
  "version": "1.0.0",
  "description": "Save webpages, articles, and content to your Memory OS dashboard",
  "permissions": ["activeTab", "storage", "contextMenus"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Save to Memory OS"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
